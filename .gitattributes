* text=auto

# Linux/WSL-safe source and build files
*.sh text eol=lf
*.py text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
Kconfig text eol=lf
Kconfig.* text eol=lf
sdkconfig text eol=lf
sdkconfig.* text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.eez-project text eol=lf
*.eez-project-ui-state text eol=lf

# Windows-only scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Don't normalize ESP-IDF managed/vendor components
firmware/managed_components/** -text
